{
  "name": "mapyou-backend",
  "version": "2.0.0",
  "description": "MapYou PWA backend — REST API + Push Notifications + Live Tracking + MongoDB",
  "main": "dist/server.js",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-esm server.ts",
