    "morgan": "^1.10.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.0",
    "@types/web-push": "^3.6.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
